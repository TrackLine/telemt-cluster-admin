# Порт на котором доступна панель (default: 3000)
PORT=3000

# Интервал опроса нод (default: 15s)
POLL_INTERVAL=15s

# MaxMind лицензионный ключ для автозагрузки GeoLite2-City.mmdb
# Получить бесплатно: https://www.maxmind.com/en/geolite2/signup
# Если задан — база скачается автоматически при первом запуске
# и будет обновляться раз в неделю
MAXMIND_LICENSE_KEY=
